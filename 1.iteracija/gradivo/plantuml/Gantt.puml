@startgantt "Ganttov diagram"

<style>
ganttDiagram {
  timeline {
    BackgroundColor white
    LineColor #e0e0e0
    FontColor #333333
    FontSize 12
  }
  task {
    FontSize 12
    FontColor #1a1a1a
  }
  arrow {
    LineColor #888888
    LineThickness 1.5
  }
  separator {
    BackgroundColor #2c3e50
    LineColor #1a252f
    FontColor white
    FontStyle bold
    FontSize 13
  }
  closed {
    BackgroundColor #f5f5f5
    FontColor #cccccc
  }
}
</style>

